{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Research Package (Research Agent)",
  "type": "object",
  "required": [
    "agent",
    "inputs",
    "outputs",
    "handoff",
    "blockers"
  ],
  "properties": {
    "agent": {
      "const": "01-research"
    },
    "version": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "inputs": {
      "type": "object",
      "required": [
        "upstream_package"
      ],
      "properties": {
        "upstream_package": {
          "type": "object"
        },
        "upstream_agent": {
          "const": "00-creative-director"
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "object",
      "required": [
        "market_insights",
        "competitor_analysis",
        "template_recommendations"
      ],
      "properties": {
        "market_insights": {
          "type": "string"
        },
        "competitor_analysis": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "template_recommendations": {
          "type": "array",
          "minItems": 1
        },
        "recommended_platform": {
          "enum": [
            "Wix",
            "Salla",
            "custom"
          ]
        }
      }
    },
    "handoff": {
      "type": "object",
      "required": [
        "next_agent"
      ],
      "properties": {
        "next_agent": {
          "const": "02-product"
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "blockers": {
      "type": "array"
    }
  }
}