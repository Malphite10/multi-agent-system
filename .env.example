# Multi-Agent System Environment Configuration
# Copy this to .env and fill in your values

# GitHub
GITHUB_TOKEN=your_github_token_here
GITHUB_REPOSITORY=org/repo-name

# APIs & Services
ANTHROPIC_API_KEY=your_anthropic_api_key
FIGMA_API_TOKEN=your_figma_token

# Security & Scanning
SNYK_TOKEN=your_snyk_token

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email Configuration (for Email Agent)
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@example.com

# Database & CMS
DATABASE_URL=postgresql://user:password@localhost/dbname
CMS_API_URL=https://cms.example.com/api
CMS_API_KEY=your_cms_api_key

# Deployment
DEPLOYMENT_TARGET=production
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_ENVIRONMENT=prod

# AWS (if using AWS deployment)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1

# Wix Integration (if building for Wix)
WIX_API_KEY=your_wix_api_key
WIX_SITE_ID=your_wix_site_id

# Salla Integration (if building for Salla/Arab market)
SALLA_API_KEY=your_salla_api_key
SALLA_CLIENT_ID=your_salla_client_id

# Logging & Monitoring
LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-dsn

# Feature Flags
ENABLE_DESIGN_VALIDATION=true
ENABLE_SOURCE_POLICY_CHECK=true
ENABLE_SBOM_GENERATION=true
ENABLE_SLACK_NOTIFICATIONS=true

# Validation Thresholds
MIN_SECURITY_SCORE=90
MIN_MAINTENANCE_SCORE=75
MAX_BUNDLE_SIZE_KB=100
APPROVAL_EXPIRY_DAYS=60

# Development
NODE_ENV=development
DEBUG=false
