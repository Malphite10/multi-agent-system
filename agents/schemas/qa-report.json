{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QA Report",
  "type": "object",
  "required": ["agent", "outputs", "handoff", "blockers"],
  "properties": {
    "agent": { "const": "08-qa" },
    "outputs": {
      "type": "object",
      "required": ["status", "score"],
      "properties": {
        "status": { "enum": ["approved", "rejected"] },
        "critical_issues": { "type": "array" },
        "warnings": { "type": "array" },
        "passed_tests": { "type": "array" },
        "score": { "type": "number" }
      }
    },
    "handoff": {
      "type": "object",
      "required": ["next_agent"],
      "properties": {
        "next_agent": { "const": "10-launch" }
      }
    },
    "blockers": { "type": "array" }
  }
}
